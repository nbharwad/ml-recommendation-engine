# ============================================================================
# Environment Variables — Local Development
# Copy this file to .env and fill in your values
# IMPORTANT: .env should be gitignored - never commit secrets
# ============================================================================

# ===== MinIO (Local S3-compatible storage) =====
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ===== Grafana (Monitoring dashboard) =====
GF_SECURITY_ADMIN_PASSWORD=admin

# ===== Redis (Feature store) =====
REDIS_PASSWORD=redis_password_here

# ===== Kafka (Local development only - Production uses MSK with SASL/IAM) =====
KAFKA_USERNAME=kafkauser
KAFKA_PASSWORD=kafkapassword

# ===== JWT Authentication =====
JWT_ISSUER=https://auth.recommendation.internal/oauth2/default
JWT_JWKS_URI=https://auth.recommendation.internal/oauth2/default/v1/keys

# ===== CORS (allowed origins, comma-separated) =====
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ===== Pseudonymization (GDPR) - must be >= 32 characters =====
PSEUDONYMIZATION_SALT=change_this_to_a_secure_random_string_at_least_32_chars

# ===== Service Ports (Usually fine as-is) =====
PORT=8080
WORKERS=2
FEATURE_SERVICE_HOST=feature-store
RETRIEVAL_SERVICE_HOST=retrieval
RANKING_SERVICE_HOST=ranking